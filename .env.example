# Use local only for initial testing or a host with persistent disk.
STORAGE_MODE=local
PUBLIC_BASE_URL=https://your-docx-plugin-domain.example.com
GENERATED_DIR=generated_files
DOCX_API_KEY=replace-with-a-long-random-token

# Refresh the live Word contents/page fields before delivering each DOCX.
# Leave enabled in production; the supplied Dockerfile includes LibreOffice.
FINALIZE_FIELDS=true
# For local Windows testing, set SOFFICE_PATH to the LibreOffice executable.
# SOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# DOCX_FINALIZER_PYTHON=C:\Program Files\LibreOffice\program\python.exe

# Restrict chart downloads to known image hosts. Add hosts only when trusted.
IMAGE_HOST_ALLOWLIST=lf-bot-studio-plugin-resource.coze.cn

# Recommended production storage: Cloudflare R2, AWS S3, or compatible object storage.
# STORAGE_MODE=s3
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=coze-generated-reports
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_KEY_PREFIX=generated-docx
# S3_PUBLIC_BASE_URL=https://files.example.com

# Default for private R2/S3 storage: return an API-hosted download link that
# stays valid for three months, while the API fetches the DOCX from R2/S3.
# Keep PUBLIC_BASE_URL set to your Render domain.
# USE_PROXY_DOWNLOAD_URLS=true
# DOWNLOAD_LINK_EXPIRY_SECONDS=7776000
# DOWNLOAD_LINK_SECRET=replace-with-a-long-random-token-or-use-DOCX_API_KEY

# Fallback only when USE_PROXY_DOWNLOAD_URLS=false. R2/S3 presigned URLs cannot
# be safely set to three months; keep this at or below 604800 seconds (7 days).
# S3_URL_EXPIRY_SECONDS=604800
